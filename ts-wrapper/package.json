{
	"name": "@tmlmobilidade/gtfs-validator",
	"description": "A GTFS Validator",
	"version": "1.0.0",
	"author": "Jusi Monteiro & João Vasconcelos",
	"license": "ISC",
	"keywords": [
		"gtfs",
		"validator",
		"gtfs-validator",
		"tmlmobilidade",
		"tml",
		"cmet",
		"carrismetropolitana"
	],
	"publishConfig": {
		"access": "public",
		"directory": "dist"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"main": "dist/index.js",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"scripts": {
		"build": "rm -rf dist && tsc",
		"lint": "eslint . && tsc --noEmit",
		"lint:fix": "eslint --fix .",
		"postinstall": "if [ ! -d dist ]; then tsx ./scripts/postinstall.ts; else node ./dist/scripts/postinstall.js; fi",
		"test": "tsx ./src/test.ts"
	},
	"dependencies": {
		"@tmlmobilidade/types": "^20250909.1559.44"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "^20250622.1204.50",
		"@dotenv-run/cli": "^1.3.6",
		"@tmlmobilidade/tsconfig": "^20250909.1559.44",
		"@types/node": "^24.3.1",
		"ts-node": "^10.9.2",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2"
	}
}
