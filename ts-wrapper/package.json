{
	"name": "@tmlmobilidade/gtfs-validator",
	"description": "A GTFS Validator",
	"version": "1.0.0",
	"author": "Jusi Monteiro & João Vasconcelos",
	"license": "ISC",
	"keywords": [
		"gtfs",
		"validator",
		"gtfs-validator",
		"tmlmobilidade",
		"tml",
		"cmet",
		"carrismetropolitana"
	],
	"publishConfig": {
		"access": "public",
		"directory": "dist"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"main": "dist/index.js",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"scripts": {
		"build": "rm -rf dist && tsc",
		"lint": "eslint ./src && tsc --noEmit",
		"lint:fix": "eslint --fix ./src",
		"postinstall": "if [ ! -d dist ]; then tsx ./scripts/postinstall.ts; else node ./dist/scripts/postinstall.js; fi",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:integration": "vitest run --grep integration",
		"test:unit": "vitest run --grep unit",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@tmlmobilidade/types": "20260526.939.0"
	},
	"devDependencies": {
		"@tmlmobilidade/eslint": "20260526.939.0",
		"@tmlmobilidade/tsconfig": "20260526.939.0",
		"@types/node": "25.9.1",
		"@vitest/coverage-v8": "4.1.7",
		"tsx": "4.22.3",
		"typescript": "6.0.3",
		"vitest": "4.1.7"
	}
}
